# Reverse proxy + HTTPS otomatis (Let's Encrypt) untuk Inventra.
# Satu domain: frontend di root, backend di /api/* dan /health.
# WAF Coraza (OWASP CRS) berjalan di depan seluruh rute — lihat ops/caddy/.
{
	email {$ACME_EMAIL}
	order coraza_waf first
}

{$DOMAIN} {
	encode gzip zstd

	coraza_waf {
		load_owasp_crs
		directives `
			Include @coraza.conf-recommended
			Include @crs-setup.conf.example
			# REST API memakai PUT/PATCH/DELETE. CRS default hanya mengizinkan
			# GET HEAD POST OPTIONS (rule 911100 METHOD-ENFORCEMENT), sehingga
			# tiap PUT/PATCH/DELETE kena skor anomali dan diblok 949110 (403).
			# Override daftar metode HARUS sebelum Include @owasp_crs/*.conf agar
			# 911100 membaca nilai baru (rule fase 1 dieksekusi urut definisi).
			SecAction "id:900201,phase:1,nolog,pass,t:none,setvar:'tx.allowed_methods=GET HEAD POST OPTIONS PUT PATCH DELETE'"
			Include @owasp_crs/*.conf
			Include /etc/caddy/coraza-exclusions.conf
			SecRuleEngine On
		`
	}

	# API + healthcheck → backend Go
	@api path /api/* /health
	handle @api {
		reverse_proxy backend:8080
	}

	# Sisanya → frontend Nuxt
	handle {
		reverse_proxy frontend:3000
	}
}

# Subdomain Grafana — situs terpisah, sengaja TANPA coraza_waf (Grafana
# punya auth sendiri; WAF generik OWASP CRS sering false-positive di UI Grafana).
monitoring.{$DOMAIN} {
	encode gzip zstd
	reverse_proxy grafana:3000
}
