SERVER_PORT=8080
ENV=development

# PostgreSQL (matches docker-compose.dev.yml)
DB_HOST=localhost
DB_PORT=5433
DB_USER=inventra
DB_PASSWORD=secret
DB_NAME=inventra_dev
DB_SSLMODE=disable

# Redis
REDIS_ADDR=localhost:6379
REDIS_PASSWORD=
REDIS_DB=0

# MinIO (S3-compatible object storage)
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin123
MINIO_BUCKET=inventra
MINIO_USE_SSL=false
ATTACHMENT_MAX_BYTES=5242880

# Auth
JWT_SECRET=change-me-in-production
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=168h

# Google OAuth2
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URL=http://localhost:8080/api/v1/auth/google/callback

# Google OAuth (ADR-0009). Leave CLIENT_ID empty to disable Google sign-in.
GOOGLE_ISSUER=https://accounts.google.com

FRONTEND_URL=http://localhost:3000

# Logging (ADR-0002)
LOG_LEVEL=info
# LOG_FORMAT: blank = auto (text in development, json otherwise); set json or text to override
LOG_FORMAT=

# Rate limiting (ADR-0004) — ⚠️ placeholder bands; tune per bank policy
RATELIMIT_ENABLED=true
RATELIMIT_TIMEOUT_MS=50
RATELIMIT_GLOBAL_PER_MIN=120
RATELIMIT_LOGIN_PER_MIN=5
RATELIMIT_LOGIN_IP_PER_MIN=20
RATELIMIT_REFRESH_PER_MIN=30

# Trusted proxy CIDRs/IPs for correct, non-spoofable client IP (rate limiting).
# Empty = trust none (use direct RemoteAddr). Behind a load balancer set to the LB CIDR(s), comma-separated.
TRUSTED_PROXIES=

# Label printing — path to the logo image embedded on asset labels.
LABEL_LOGO_PATH=assets/logo-btn.png

# Bulk import (CSV/XLSX)
IMPORT_MAX_ROWS=10000
IMPORT_MAX_BYTES=10485760
IMPORT_WORKER_ENABLED=true
IMPORT_WORKER_POLL=2s

# In-app notifications. NOTIFICATION_WORKER_ENABLED gates the relay, the fan-out
# consumer and the sweeper as one unit. NOTIFICATION_RETENTION_DAYS=0 keeps
# notifications forever (the due scan still runs).
NOTIFICATION_WORKER_ENABLED=true
NOTIFICATION_RELAY_POLL=2s
NOTIFICATION_STREAM_MAXLEN=10000
NOTIFICATION_CLAIM_MIN_IDLE=60s
NOTIFICATION_SWEEP_POLL=1h
NOTIFICATION_RETENTION_DAYS=90

# Email (password reset + notifications). MAIL_ENABLED=false uses a log-only sender.
# EMAIL_PROVIDER selects the transport: "smtp" (default) or "resend" (HTTP API).
MAIL_ENABLED=false
EMAIL_PROVIDER=smtp
# Resend HTTP API (EMAIL_PROVIDER=resend). Keep the key secret — never commit it.
# Falls back to the log-only sender when empty. FROM must be a verified sender.
RESEND_API_KEY=
# SMTP relay (EMAIL_PROVIDER=smtp). Dev/e2e use Mailpit (host=mailpit, port=1025).
SMTP_HOST=
SMTP_PORT=1025
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=no-reply@inventra.local
SMTP_FROM_NAME=Inventra
SMTP_TLS=none
PASSWORD_RESET_TTL=30m
