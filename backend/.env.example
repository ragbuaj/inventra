SERVER_PORT=8080
ENV=development

# PostgreSQL (matches docker-compose.dev.yml)
DB_HOST=localhost
DB_PORT=5433
DB_USER=inventra
DB_PASSWORD=secret
DB_NAME=inventra_dev
DB_SSLMODE=disable

# Redis
REDIS_ADDR=localhost:6379
REDIS_PASSWORD=
REDIS_DB=0

# MinIO (S3-compatible object storage)
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin123
MINIO_BUCKET=inventra
MINIO_USE_SSL=false

# Auth
JWT_SECRET=change-me-in-production
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=168h

# Google OAuth2
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URL=http://localhost:8080/api/v1/auth/google/callback

FRONTEND_URL=http://localhost:3000

# Logging (ADR-0002)
LOG_LEVEL=info
# LOG_FORMAT: blank = auto (text in development, json otherwise); set json or text to override
LOG_FORMAT=

# Rate limiting (ADR-0004) — ⚠️ placeholder bands; tune per bank policy
RATELIMIT_ENABLED=true
RATELIMIT_TIMEOUT_MS=50
RATELIMIT_GLOBAL_PER_MIN=120
RATELIMIT_LOGIN_PER_MIN=5
RATELIMIT_LOGIN_IP_PER_MIN=20
RATELIMIT_REFRESH_PER_MIN=30
