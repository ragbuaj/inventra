# syntax=docker/dockerfile:1
#
# Development image: runs `nuxt dev` with Vite HMR. Source is bind-mounted at
# /app by docker-compose.watch.yml, while node_modules stays in a named volume
# (so the container keeps its own Linux-native install, not the host's).
# Not for production — see Dockerfile for that.
FROM node:24-alpine
WORKDIR /app
RUN corepack enable

# Install deps into the image; the compose named volume for /app/node_modules
# is seeded from this layer on first run.
COPY package.json pnpm-lock.yaml pnpm-workspace.yaml ./
RUN pnpm install --frozen-lockfile

ENV HOST=0.0.0.0
ENV PORT=3000
EXPOSE 3000
# --host binds 0.0.0.0 so the dev server (and its HMR socket) is reachable from
# the host browser at http://localhost:3000.
CMD ["pnpm", "dev", "--host"]
