# Allow pnpm to resync node_modules without an interactive prompt. Required for
# the Docker watch stack: `nuxt dev` runs pnpm non-interactively (no TTY), so when
# the named-volume node_modules drifts from the lockfile pnpm would otherwise abort
# with ERR_PNPM_ABORTED_REMOVE_MODULES_DIR_NO_TTY. This only skips the purge
# confirmation; it does NOT enable frozen-lockfile (unlike setting CI=true).
confirm-modules-purge=false
