meta {
  name: Create
  type: http
  seq: 2
}

post {
  url: {{baseUrl}}/api/v1/users
  body: json
  auth: bearer
}

auth:bearer {
  token: {{accessToken}}
}

body:json {
  {
    "name": "Staf Satu",
    "email": "staf1@inventra.local",
    "password": "staf12345",
    "role_id": "{{stafRoleId}}"
  }
}

script:post-response {
  if (res.status === 201) {
    bru.setEnvVar("userId", res.body.id);
  }
}
