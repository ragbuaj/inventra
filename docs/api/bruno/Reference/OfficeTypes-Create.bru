meta {
  name: OfficeTypes - Create
  type: http
  seq: 6
}

post {
  url: {{baseUrl}}/api/v1/office-types
  body: json
  auth: bearer
}

auth:bearer {
  token: {{accessToken}}
}

body:json {
  {
    "name": "Kantor Pusat"
