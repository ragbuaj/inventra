meta {
  name: Brands - Create
  type: http
  seq: 2
}

post {
  url: {{baseUrl}}/api/v1/brands
  body: json
  auth: bearer
}

auth:bearer {
  token: {{accessToken}}
}

body:json {
  {
    "name": "Dell"
  }
}

script:post-response {
  if (res.status === 201) {
    bru.setEnvVar("brandId", res.body.id);
  }
}
