# Normalize line endings to LF in the repo (CI runs on Linux).
* text=auto eol=lf

# Explicit LF for source/config files.
*.go    text eol=lf
*.sql   text eol=lf
*.ts    text eol=lf
*.vue   text eol=lf
*.mjs   text eol=lf
*.json  text eol=lf
*.yml   text eol=lf
*.yaml  text eol=lf
*.md    text eol=lf
*.css   text eol=lf

# Binary assets.
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.ico   binary
*.webp  binary
