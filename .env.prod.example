# ─────────────────────────────────────────────────────────────
# Inventra — konfigurasi PRODUKSI. Salin ke `.env.prod` lalu isi.
#   cp .env.prod.example .env.prod
# JANGAN commit `.env.prod` (berisi rahasia). Sudah di-.gitignore.
# ─────────────────────────────────────────────────────────────

# Domain & TLS (Caddy meminta sertifikat Let's Encrypt otomatis)
DOMAIN=inventra.example.com
ACME_EMAIL=you@example.com

# Rahasia — WAJIB diganti. Bangkitkan dengan:  openssl rand -hex 32
DB_PASSWORD=ganti-password-db-yang-kuat
JWT_SECRET=ganti-dengan-openssl-rand-hex-32
MINIO_ROOT_USER=inventra-minio
MINIO_ROOT_PASSWORD=ganti-password-minio-yang-kuat

# Google OAuth (opsional). Kosongkan CLIENT_ID untuk menonaktifkan login Google.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Email transaksional (reset password, notifikasi ganti password/email).
# MAIL_ENABLED=false memakai sender log-only: email hanya dicatat, tidak dikirim.
MAIL_ENABLED=true
EMAIL_PROVIDER=resend
# API key Resend (https://resend.com) — rahasia, jangan di-commit.
# Kosong = sender jatuh ke mode log dan email TIDAK terkirim.
RESEND_API_KEY=
# Alamat pengirim. Domainnya harus SUDAH DIVERIFIKASI di dashboard Resend,
# jika tidak Resend menolak dengan 403 domain is not verified.
SMTP_FROM=no-reply@inventra.example.com
SMTP_FROM_NAME=Inventra
